{
  "name": "cesium-project",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "bench": "vitest bench",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "audit:prod": "npm audit --omit=dev",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "cesium": "^1.138.0",
    "element-plus": "^2.13.2",
    "exceljs": "^4.4.0",
    "pinia": "^2.3.1",
    "vue": "^3.5.29"
  },
  "lint-staged": {
    "*.{js,vue,cjs,json,css}": [
      "prettier --write"
    ],
    "*.{js,vue}": [
      "eslint --fix"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^8.57.1",
    "@types/node": "^20.19.35",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vitest/coverage-v8": "^4.0.18",
    "@vue/compiler-sfc": "^3.5.29",
    "autoprefixer": "^10.4.27",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^9.33.0",
    "happy-dom": "^20.7.0",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.19",
    "unplugin-auto-import": "^20.3.0",
    "unplugin-vue-components": "^30.0.0",
    "vite": "^5.4.21",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-externals": "^0.6.2",
    "vitest": "^4.0.18"
  }
}
